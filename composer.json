{
    "name": "parf/composer-php85-template",
    "description": "PHP 8.5 Template for composer/packagist",
    "keywords": ["template", "php85"],
    "license": "MIT",
    "authors": [
        {
            "name": "Sergey Parf",
            "email": "sergey.porfiriev@gmail.com"
        }
    ],
    "type": "project",
    "require": {
		"php": ">=8.5"
    },
    "require-dev": {
    },    
    "autoload": {
        "psr-4": {
            "TemplatePackage\\": "src/TemplatePackage/"
        }
    },
  "scripts": {
    "check": "sh scripts/check.sh",
    "dry": "sh scripts/dry.sh",
    "fix": "sh scripts/fix.sh",
    "doc": "sh scripts/doc.sh",
    "phpstan": "sh scripts/with-managed-path.sh phpstan analyse -c phpstan.neon src",
    "stan": "sh scripts/with-managed-path.sh phpstan analyse -c phpstan.neon src",
    "stan-q": "sh scripts/with-managed-path.sh phpstan -q analyse -c phpstan.neon src",
    "stan2": "sh scripts/with-managed-path.sh phpstan analyse --level 2 -c phpstan.neon src",
    "stan3": "sh scripts/with-managed-path.sh phpstan analyse --level 3 -c phpstan.neon src",
    "stan4": "sh scripts/with-managed-path.sh phpstan analyse --level 4 -c phpstan.neon src",
    "stan5": "sh scripts/with-managed-path.sh phpstan analyse --level 5 -c phpstan.neon src",
    "stan6": "sh scripts/with-managed-path.sh phpstan analyse --level 6 -c phpstan.neon src",
    "phpdoc": "sh scripts/with-managed-path.sh phpDocumentor.phar -d 'src' -t doc",
    "psalm": "sh scripts/with-managed-path.sh psalm.phar",
    "psalm-dry": "sh scripts/with-managed-path.sh psalm.phar --alter --issues=MissingClosureReturnType,UnusedVariable,MissingReturnType,InvalidReturnType --dry-run",
    "psalm-fix": "sh scripts/with-managed-path.sh psalm.phar --alter --issues=MissingClosureReturnType,UnusedVariable,MissingReturnType,InvalidReturnType",
    "mago-lint": "sh scripts/with-managed-path.sh mago --php-version=8.5 lint src",
    "mago-analyze": "sh scripts/with-managed-path.sh mago --php-version=8.5 analyze src",
    "mago-format-dry": "sh scripts/with-managed-path.sh mago --php-version=8.5 format --dry-run src",
    "mago-format-check": "sh scripts/with-managed-path.sh mago --php-version=8.5 format --check src",
    "mago-format": "sh scripts/with-managed-path.sh mago --php-version=8.5 format src",
    "cs-dry": "sh scripts/with-managed-path.sh php-cs-fixer fix --diff -v --dry-run src",
    "cs-fix": "sh scripts/with-managed-path.sh php-cs-fixer fix --diff -v src",
    "rector-dry": "sh scripts/with-managed-path.sh rector process src --dry-run",
    "rector": "sh scripts/with-managed-path.sh rector process src",
    "stest": "sh scripts/with-managed-path.sh stest-all tests",
    "stest-q": "sh scripts/with-managed-path.sh stest-all -q tests",
    "pest": "sh scripts/with-managed-path.sh php scripts/pest-runner.php",
    "pest-q": "sh scripts/with-managed-path.sh php scripts/pest-runner.php --compact",
    "test": "sh scripts/test-suite.sh",
    "test-q": "sh scripts/test-suite.sh --quiet",
    "lint": "find src -type f -name '*.php' -print0 | xargs -0 -n1 -P4 php -l -n | (! grep -v \"No syntax errors detected\" )"
  }    
}
