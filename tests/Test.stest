# lines starting with ";" executed, but not tested
; $h = new \TemplatePackage\HelloWorlds;
$h->hello("World");
    'Hello, World!';

$h->hello("Mundo", "es");
    'Hola, Mundo!';

$h->helloMany(["World", "Mars"]);
    ['Hello, World!', 'Hello, Mars!'];

$h->excitedHello("team");
    'HELLO, TEAM!';

$h->summary(["Earth", "Venus"], "fr");
    'Bonjour, Earth! | Bonjour, Venus!';
